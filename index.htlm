<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Car Crew</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #111;
            color: white;
            text-align: center;
        }

        header {
            padding: 60px 20px;
        }

        h1 {
            font-size: 40px;
            margin-bottom: 10px;
        }

        p {
            font-size: 18px;
            color: #ccc;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 20px;
            background: white;
            color: black;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
        }

        .btn:hover {
            background: #ddd;
        }

        footer {
            margin-top: 50px;
            padding: 20px;
            font-size: 14px;
            color: #777;
        }
    </style>
</head>

<body>

    <header>
        <h1>🚗 My Car Crew</h1>
        <p>Welcome to our official website</p >

        <a class="btn" href=" " target="_blank">
            Follow Us on Instagram
        </a >
    </header>

    <footer>
        © 2026 My Car Crew. All rights reserved.
    </footer>

</body>
</html>
